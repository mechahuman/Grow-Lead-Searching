# ═══════════════════════════════════════════════════════════════════════════════
# Autonomous YouTube Lead Discovery System - Environment Configuration Example
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env.local and fill in your actual credentials.
# Never commit .env.local to git (it contains secrets).

# ─── Autonomous System - Supabase (separate project) ──────────────────────────
# Get these from your Supabase project settings (Authentication tab)
NEXT_PUBLIC_AUTONOMOUS_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_AUTONOMOUS_SUPABASE_ANON_KEY=your-anon-key-here
AUTONOMOUS_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── External APIs ───────────────────────────────────────────────────────────
# YouTube Data API key
# Get from: https://console.cloud.google.com
# Steps:
#   1. Create a new project
#   2. Enable "YouTube Data API v3"
#   3. Create an API key (Credentials tab)
YOUTUBE_API_KEY=your-youtube-api-key-here

# Groq API key (free tier with 14,400 requests/day)
# Get from: https://console.groq.com/keys
# Groq provides free LLM access (llama, mixtral models)
GROQ_API_KEY=your-groq-api-key-here

# ─── Autonomous System - Discovery Configuration ──────────────────────────────
# How many YouTube search queries to generate per run
# Each query costs 100 YouTube API units
# With 10,000/day limit, max ~24 runs per day with 4 queries
AUTONOMOUS_QUERIES_PER_RUN=4

# How many results to fetch per query
# Each batch of 50 channels costs 1 YouTube API unit
# Recommended: 8 (safe, balanced discovery)
AUTONOMOUS_RESULTS_PER_QUERY=8

# Minimum subscriber count (inclusive)
# Set to filter out very small channels
# Example: 1000 (only discover channels with 1k+ subs)
AUTONOMOUS_MIN_SUBSCRIBERS=1000

# Maximum subscriber count (inclusive)
# Set to filter out mega-channels
# Example: 500000 (only discover channels with <500k subs)
AUTONOMOUS_MAX_SUBSCRIBERS=500000

# Groq LLM model for query generation and channel qualification
# Recommended: llama-3.3-70b-versatile (free tier, excellent quality)
# Alternatives: mixtral-8x7b-32768, llama-2-70b-chat
AUTONOMOUS_GROQ_MODEL=llama-3.3-70b-versatile

# ─── API Authentication ──────────────────────────────────────────────────────
# Secret token for /api/autonomous/run endpoint
# Must match between AUTONOMOUS_RUN_SECRET (server) and NEXT_PUBLIC_AUTONOMOUS_RUN_SECRET (browser)
# Generate a secure random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or use: openssl rand -hex 32
AUTONOMOUS_RUN_SECRET=your-random-secret-here
NEXT_PUBLIC_AUTONOMOUS_RUN_SECRET=your-random-secret-here
